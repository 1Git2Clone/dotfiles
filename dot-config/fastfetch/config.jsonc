// Load with --load-config examples/2.jsonc
// Note that you must replace the image path to an existing image to display it.

{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "kitty-icat",
    "source": "~/dotfiles/dot-config/fastfetch/icons/HuTaoSmall.png",
    "color": {
      "1": "red",
      "2": "red",
    },
  },
  "display": {
    "separator": " в•‘ ",
    "color": {
      "separator": "red",
    },
    "constants": ["в• в•җ[вқӨпёҸ]в•җв•Ј", ".ЛҡМҮМЈвң§.вӢҶ вң¶Л–В·Лі.вңҰЛҡ", "ЛҡвңҰ.ЛіВ·Л–вң¶ вӢҶ.вң§МЈМҮЛҡ."],
  },
  "modules": [
    {
      "type": "custom",
      "format": "в•”в•җв•җв•җв•җв•җв•җв•— {$2}  USER  {$3}",
      "outputcolor": "red",
    },
    {
      "type": "title",
      "color": {
        "user": "red",
        "at": "red",
        "host": "red",
      },
      "format": "в•‘  пҖҮ   в•‘ {user-name}@{host-name} ",
      "outputColor": "red",
    },
    {
      "type": "custom",
      "format": "{$1} {$2}   OS   {$3}",
      "outputcolor": "red",
    },
    {
      "type": "os",
      "key": "в•‘  {icon}  ",
      "keyColor": "red",
    },
    {
      "type": "kernel",
      "key": "в•‘  пҖ“  ",
      "keyColor": "red",
    },
    {
      "type": "packages",
      "key": "в•‘  у°Ҹ–  ",
      "keyColor": "red",
    },
    {
      "type": "shell",
      "key": "в•‘  п’ү  ",
      "keyColor": "red",
    },
    {
      "type": "terminal",
      "key": "в•‘  оһ•  ",
      "keyColor": "red",
    },
    {
      "type": "custom",
      "format": "{$1} {$2}   PC   {$3}",
      "outputColor": "red",
    },
    {
      "type": "host",
      "key": "в•‘  у°Ңў  ",
      "keyColor": "red",
    },
    {
      "type": "cpu",
      "key": "в•‘  у°»   ",
      "keyColor": "red",
    },
    {
      "type": "gpu",
      "key": "в•‘  у°Қӣ  ",
      "keyColor": "red",
    },
    {
      "type": "disk",
      "key": "в•‘  пӮ   ",
      "keyColor": "red",
    },
    {
      "type": "memory",
      "key": "в•‘  у°‘ӯ  ",
      "keyColor": "red",
    },
    {
      "type": "swap",
      "key": "в•‘  у°“Ў  ",
      "keyColor": "red",
    },
    {
      "type": "uptime",
      "key": "в•‘  у°…җ  ",
      "keyColor": "red",
    },
    {
      "type": "display",
      "key": "в•‘  у°Қ№  ",
      "keyColor": "red",
    },
    {
      "type": "custom",
      "format": "{$1} {$2}   рҹҺ§   {$3}",
      "outputColor": "red",
    },
    {
      "type": "player",
      "key": "в•‘  у°Ҙ   ",
      "keyColor": "red",
    },
    {
      "type": "media",
      "key": "в•‘  у°қҡ  ",
      "keyColor": "red",
    },
    {
      "type": "custom",
      "format": "в•ҡв•җв•җв•җв•җв•җв•җв•қ {$2}вӮҠвҖ§ аӯЁаӯ§ вҖ§вӮҠ{$3}",
      "outputColor": "red",
    },
  ],
}
