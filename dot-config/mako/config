# Mainly inspired from:
# - https://github.com/fluix-dev/dotfiles/blob/master/mako/config

# Take a look at the mako manpage with the command:
#   man 5 mako
# To view all configuration options.

font=JetBrainsMono Nerd
format=<b>%a ⏵</b> %s\n%b
sort=-time
output=eDP
layer=overlay
anchor=bottom-center
background-color=#330101
width=300
height=110
margin=5
padding=0,5,10
border-size=2
border-color=#551111
border-radius=15
icons=0
max-icon-size=64
default-timeout=2500
ignore-timeout=1

[urgency=normal]
border-color=#d08770

[urgency=high]
border-color=#bf616a
default-timeout=0
